{
  "name": "nihongopage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:full": "pnpm test:coverage && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui",
    "test:e2e:headed": "pnpm build && playwright test --headed --workers=1",
    "test:e2e:update": "pnpm build && playwright test tests/e2e/visual.spec.ts --project=desktop --project=mobile --update-snapshots=all",
    "test:e2e:update:container": "./scripts/update-visuals-in-container.sh",
    "test:update-snapshots": "pnpm test:e2e:update",
    "verify": "pnpm lint && pnpm format:check && pnpm test:coverage && pnpm test:e2e"
  },
  "dependencies": {
    "i18next": "26.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "17.0.9",
    "react-router-dom": "^7.18.1",
    "styled-components": "6.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "oxlint": "^1.74.0",
    "playwright": "1.61.1",
    "prettier": "^3.9.5",
    "typescript": "~7.0.2",
    "vite": "^8.1.1",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0"
  }
}
